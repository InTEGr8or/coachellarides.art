---
import TabNav from './TabNav.astro';
import VenueTable from './VenueTable.astro';
---

<div class="scheduler">
  <h1>Coachella Rides</h1>
  
  <TabNav days={["Fri", "Sat", "Sun"]} />

  <VenueTable />
</div>

<style>
  .scheduler {
    padding: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }
  h1 {
    text-align: center;
    color: var(--dark-charcoal);
  }
</style>

