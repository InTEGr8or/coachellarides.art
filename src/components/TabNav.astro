---
interface Props {
  days: string[];
}
const { days } = Astro.props;
---

<nav class="tabs">
  {days.map((day, index) => (
    <button class={`btn btn-secondary ${index === 0 ? "active" : ""}`} data-day={day}>{day}</button>
  ))}
</nav>

<script>
  const buttons = document.querySelectorAll('.tabs button');
  const heading = document.querySelector('h1');

  const dates = {
    "Fri": "4/17",
    "Sat": "4/18",
    "Sun": "4/19"
  };

  buttons.forEach(button => {
    button.addEventListener('click', () => {
      buttons.forEach(btn => btn.classList.remove('active'));
      button.classList.add('active');
      
      const day = button.getAttribute('data-day');
      if (heading) {
        heading.textContent = `Coachella Rides - ${day} ${dates[day] || ''}`;
      }
    });
  });
</script>

<style>
  .tabs {
    display: flex;
    justify-content: center;
    gap: 1rem;
    padding: 1rem;
  }
  .tabs button {
    font-size: 2em;
    transition: background 0.2s;
  }
  .tabs button.active {
    background: var(--palm-green);
  }
</style>
