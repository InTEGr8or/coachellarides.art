---
import { getEntry, render } from 'astro:content';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const entry = await getEntry('info-banners', slug);

if (!entry) {
  throw new Error(`Could not find banner with slug: ${slug}`);
}

const { Content } = await render(entry);
---

<div class="info-banner">
  <Content />
</div>

<style is:global>
  .info-banner {
    background: rgba(255, 255, 255, 0.4);
    padding: 1.5rem;
    border-radius: 10px;
    margin-bottom: 2rem;
    border-left: 5px solid var(--palm-green);
    color: var(--dark-charcoal);
  }
  .info-banner h3 { margin-top: 0; }
  .info-banner h4 { margin: 0.5rem 0 0.25rem; color: var(--dark-charcoal); }
  .info-banner ul { padding-left: 1.5rem; }
  .info-banner table { margin-bottom: 0.5rem; }
  .info-banner table:last-child { margin-bottom: 0; }
  .info-banner table th, .info-banner table td { font-size: 0.9rem; }
</style>
