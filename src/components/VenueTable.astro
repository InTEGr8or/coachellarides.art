---
import venues from '../data/venues.json';

// Generate 30-min slots from 12:00 to 20:30 (18 slots total)
const slots = Array.from({ length: 18 }, (_, i) => {
  const hour = Math.floor(12 + i / 2);
  const minute = (i % 2) === 0 ? "00" : "30";
  const displayHour = hour > 12 ? hour - 12 : hour;
  const ampm = hour >= 12 ? "PM" : "AM";
  return `${displayHour}:${minute} ${ampm}`;
});
---

<table class="scheduler-table">
  <thead>
    <tr>
      <th>Time</th>
      {venues.map(v => <th>{v.name}<br /><small>({v.capacity} seats)</small></th>)}
    </tr>
  </thead>
  <tbody>
    {slots.map(slot => (
      <tr>
        <td>{slot}</td>
        {venues.map(v => (
          <td>
            <button data-venue={v.name} data-time={slot} class="btn btn-secondary signup-btn">Book</button>
          </td>
        ))}
      </tr>
    ))}
  </tbody>
</table>

<!-- Booking Modal -->
<div id="booking-modal" class="modal">
  <div class="modal-content">
    <h3>Book Ride</h3>
    <p id="booking-info" class="booking-info"></p>
    <p id="status-message" class="status-message"></p>
    <form id="booking-form">
      <input type="hidden" name="venue" id="venue-input" />
      <input type="hidden" name="time" id="time-input" />
      <input type="text" name="name" placeholder="Name" required />
      <input type="tel" name="phone" id="phone-input" placeholder="(123) 456-7890" required />
      <input type="text" name="pickup" placeholder="Pickup Location" required />
      <div class="modal-buttons">
        <button type="submit" class="btn btn-primary">Submit</button>
        <button type="button" id="close-modal" class="btn btn-cancel">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabaseClient';
  import IMask from 'imask';

  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('booking-modal');
    const form = document.getElementById('booking-form');
    const closeBtn = document.getElementById('close-modal');
    const venueInput = document.getElementById('venue-input') as HTMLInputElement;
    const timeInput = document.getElementById('time-input') as HTMLInputElement;
    const bookingInfo = document.getElementById('booking-info');
    const statusMessage = document.getElementById('status-message');
    const phoneInput = document.getElementById('phone-input');

    let phoneMask;
    if (phoneInput) {
      phoneMask = IMask(phoneInput, { mask: '(000) 000-0000' });
    }

    document.querySelectorAll('.signup-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        venueInput.value = btn.getAttribute('data-venue');
        timeInput.value = btn.getAttribute('data-time');
        bookingInfo.textContent = `${venueInput.value} at ${timeInput.value}`;
        statusMessage.textContent = '';
        modal.style.display = 'block';
      });
    });

    closeBtn.addEventListener('click', () => modal.style.display = 'none');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const phoneValue = phoneMask ? phoneMask.unmaskedValue : '';
      if (phoneValue.length !== 10) {
        statusMessage.textContent = 'Please enter a valid 10-digit phone number.';
        statusMessage.style.color = '#cc0000';
        return;
      }

      statusMessage.textContent = 'Submitting...';
      statusMessage.style.color = 'var(--dark-charcoal)';

      const formData = new FormData(form);
      const day = document.querySelector('.tabs button.active')?.getAttribute('data-day') || 'Fri';

      const { error } = await supabase.from('bookings').insert({
        name: formData.get('name'),
        phone: phoneValue,
        pickup_location: formData.get('pickup'),
        day: day,
        venue: formData.get('venue'),
        time_slot: formData.get('time')
      });

      if (error) {
        statusMessage.textContent = 'Error: ' + error.message;
        statusMessage.style.color = '#cc0000';
      } else {
        statusMessage.textContent = 'Booking successful!';
        statusMessage.style.color = 'var(--palm-green)';
        setTimeout(() => { modal.style.display = 'none'; form.reset(); if(phoneMask) phoneMask.value = ''; }, 1500);
      }
    });
  });
</script>
