---
import venues from '../data/venues.json';
const slots = Array.from({ length: 9 }, (_, i) => `${12 + i}:00 - ${13 + i}:00`);
---

<table class="scheduler-table">
  <thead>
    <tr>
      <th>Time</th>
      {venues.map(v => <th>{v.name} <br /><small>({v.capacity} seats)</small></th>)}
    </tr>
  </thead>
  <tbody>
    {slots.map(slot => (
      <tr>
        <td>{slot}</td>
        {venues.map(v => (
          <td>
            <button class="signup-btn" data-venue={v.name} data-time={slot}>Book</button>
          </td>
        ))}
      </tr>
    ))}
  </tbody>
</table>

<!-- Booking Modal -->
<div id="booking-modal" class="modal">
  <div class="modal-content">
    <h3>Book Ride</h3>
    <form id="booking-form">
      <input type="hidden" name="venue" id="venue-input" />
      <input type="hidden" name="time" id="time-input" />
      <input type="text" name="name" placeholder="Name" required />
      <input type="email" name="email" placeholder="Email" required />
      <input type="tel" name="phone" placeholder="Phone" required />
      <button type="submit">Submit</button>
      <button type="button" id="close-modal">Cancel</button>
    </form>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabaseClient';

  const modal = document.getElementById('booking-modal');
  const form = document.getElementById('booking-form');
  const closeBtn = document.getElementById('close-modal');

  document.querySelectorAll('.signup-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('venue-input').value = btn.getAttribute('data-venue');
      document.getElementById('time-input').value = btn.getAttribute('data-time');
      modal.style.display = 'block';
    });
  });

  closeBtn.addEventListener('click', () => modal.style.display = 'none');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const day = document.querySelector('.tabs button.active').getAttribute('data-day');

    const { error } = await supabase.from('bookings').insert({
      name: formData.get('name'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      day: day,
      venue: formData.get('venue'),
      time_slot: formData.get('time')
    });

    if (error) {
      alert('Error booking ride: ' + error.message);
    } else {
      alert('Booking successful!');
      modal.style.display = 'none';
      form.reset();
    }
  });
</script>

<style>
  .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); }
  .modal-content { background: white; margin: 15% auto; padding: 20px; width: 300px; border-radius: 10px; color: #033; }
  .scheduler-table {
    width: 100%;
    border-collapse: collapse;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 15px;
    overflow: hidden;
    backdrop-filter: blur(5px);
  }
  .scheduler-table th, .scheduler-table td {
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.75rem;
    text-align: center;
    color: #033;
  }
  .scheduler-table th {
    background: rgba(255, 255, 255, 0.2);
  }
  .signup-btn {
    cursor: pointer;
    background: var(--mountain-clay);
    border: none;
    padding: 0.4rem 0.8rem;
    border-radius: 5px;
    color: white;
    font-weight: bold;
    transition: background 0.2s;
  }
  .signup-btn:hover {
    background: var(--palm-green);
  }
</style>
