---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admin Dashboard">
  <div class="admin-container">
    <div class="header">
      <a href="/" class="btn btn-secondary">Back to Home</a>
      <h1>Pending Bookings</h1>
    </div>
    <div class="table-wrapper">
      <table id="bookings-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Phone</th>
            <th>Day</th>
            <th>Vehicle</th>
            <th>Time</th>
            <th>Pickup</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="bookings-body"></tbody>
      </table>
    </div>
    <button id="logout-btn" class="btn btn-cancel">Logout</button>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabaseClient';

  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) window.location.href = '/login';
  }

  async function loadBookings() {
    const { data, error } = await supabase
      .from('bookings')
      .select('*')
      .in('status', ['pending', 'confirmed'])
      .order('day')
      .order('venue')
      .order('time_slot');

    if (error) {
      console.error(error);
      return;
    }

    const formatPhone = (p) => p.replace(/(\d{3})(\d{3})(\d{4})/, '($1) $2-$3');
    const body = document.getElementById('bookings-body');

    body.innerHTML = data.map(b => `
      <tr>
        <td>${b.name}</td>
        <td><a href="tel:${b.phone}" class="phone-link">${formatPhone(b.phone)}</a></td>
        <td>${b.day}</td>
        <td>${b.venue}</td>
        <td>${b.time_slot}</td>
        <td>${b.pickup_location}</td>
        <td>
          ${b.status === 'pending' 
            ? `<button data-id="${b.id}" data-venue="${b.venue}" data-time="${b.time_slot}" data-day="${b.day}" class="btn btn-primary action-btn">Confirm</button>`
            : `<span class="status-${b.status}">${b.status}</span>`}
        </td>
      </tr>
    `).join('');
  }

  document.getElementById('bookings-body').addEventListener('click', async (e) => {
    if (e.target.classList.contains('action-btn')) {
      const id = e.target.getAttribute('data-id');
      const venue = e.target.getAttribute('data-venue');
      const time = e.target.getAttribute('data-time');
      const day = e.target.getAttribute('data-day');

      // 1. Confirm the selected booking
      const { error: confirmError } = await supabase
        .from('bookings')
        .update({ status: 'confirmed' })
        .eq('id', id);

      // 2. Reject all other pending bookings for the same vehicle, time, and day
      const { error: rejectError } = await supabase
        .from('bookings')
        .update({ status: 'rejected' })
        .eq('venue', venue)
        .eq('time_slot', time)
        .eq('day', day)
        .eq('status', 'pending')
        .neq('id', id);

      if (confirmError || rejectError) {
        console.error('Error:', confirmError || rejectError);
        alert('Error updating booking status.');
      } else {
        loadBookings();
      }
    }
  });

  document.getElementById('logout-btn').addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });

  checkAuth();
  loadBookings();
</script>
