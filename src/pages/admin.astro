---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admin Dashboard">
  <div class="admin-container">
    <div class="header">
      <a href="/" class="signup-btn">Back to Home</a>
      <h1>Pending Bookings</h1>
    </div>
    <div id="bookings-container"></div>
    <button id="logout-btn" class="cancel-btn">Logout</button>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabaseClient';

  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) window.location.href = '/login';
  }

  async function loadBookings() {
    const { data, error } = await supabase
      .from('bookings')
      .select('*')
      .eq('status', 'pending');

    if (error) {
      console.error(error);
      return;
    }

    const formatPhone = (p) => p.replace(/(\d{3})(\d{3})(\d{4})/, '($1) $2-$3');
    const container = document.getElementById('bookings-container');

    container.innerHTML = data.map(b => `
      <div class="booking-card">
        <div class="card-content">
          <div class="field"><strong>Name:</strong> ${b.name}</div>
          <div class="field"><strong>Phone:</strong> <a href="tel:${b.phone}" class="phone-link">${formatPhone(b.phone)}</a></div>
          <div class="field"><strong>Day:</strong> ${b.day}</div>
          <div class="field"><strong>Venue:</strong> ${b.venue}</div>
          <div class="field"><strong>Time:</strong> ${b.time_slot}</div>
          <div class="field"><strong>Pickup:</strong> ${b.pickup_location}</div>
        </div>
        <button data-id="${b.id}" class="action-btn confirm-btn">Confirm</button>
      </div>
    `).join('');
  }

  document.getElementById('bookings-container').addEventListener('click', async (e) => {
    if (e.target.classList.contains('confirm-btn')) {
      const id = e.target.getAttribute('data-id');
      const { error } = await supabase
        .from('bookings')
        .update({ status: 'confirmed' })
        .eq('id', id);

      if (error) console.error('Error confirming:', error.message);
      else loadBookings();
    }
  });

  document.getElementById('logout-btn').addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });

  checkAuth();
  loadBookings();
</script>

<style>
  .admin-container { padding: 2rem; max-width: 800px; margin: 0 auto; background: rgba(255, 255, 255, 0.4); border-radius: 15px; backdrop-filter: blur(5px); }
  .header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  h1 { margin: 0; color: var(--dark-charcoal); }
  .booking-card {
    background: rgba(255, 255, 255, 0.3);
    padding: 1rem;
    border-radius: 10px;
    border: 1px solid var(--mountain-clay);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  @media (min-width: 600px) {
    .booking-card { flex-direction: row; justify-content: space-between; align-items: center; }
  }
  .card-content { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 0.5rem; flex-grow: 1; }
  .field { color: var(--dark-charcoal); }
  .phone-link { color: var(--dark-charcoal); text-decoration: underline; font-family: monospace; }
  .signup-btn { text-decoration: none; display: inline-block; cursor: pointer; background: var(--mountain-clay); border: none; padding: 0.5rem 1rem; border-radius: 5px; color: white; font-weight: bold; }
  .signup-btn:hover { background: var(--palm-green); }
  .action-btn { cursor: pointer; background: var(--palm-green); border: none; padding: 0.6rem 1rem; border-radius: 5px; color: white; font-weight: bold; transition: background 0.2s; }
  .action-btn:hover { background: var(--mountain-clay); }
  .cancel-btn { cursor: pointer; background: #ccc; border: none; padding: 0.8rem; border-radius: 5px; margin-top: 1rem; color: var(--dark-charcoal); }
</style>

