---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admin Dashboard">
  <div class="admin-container">
    <div class="header">
      <a href="/" class="signup-btn">Back to Home</a>
      <h1>Pending Bookings</h1>
    </div>
    <table id="bookings-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Phone</th>
          <th>Day</th>
          <th>Venue</th>
          <th>Time</th>
          <th>Pickup</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody id="bookings-body"></tbody>
    </table>
    <button id="logout-btn" class="cancel-btn">Logout</button>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabaseClient';

  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) window.location.href = '/login';
  }

  async function loadBookings() {
    const { data, error } = await supabase
      .from('bookings')
      .select('*')
      .eq('status', 'pending');

    if (error) {
      console.error(error);
      return;
    }

    const body = document.getElementById('bookings-body');
    body.innerHTML = data.map(b => `
      <tr>
        <td>${b.name}</td>
        <td><a href="tel:${b.phone}" class="phone-link">${b.phone}</a></td>
        <td>${b.day}</td>
        <td>${b.venue}</td>
        <td>${b.time_slot}</td>
        <td>${b.pickup_location}</td>
        <td><button onclick="confirmBooking(${b.id})" class="submit-btn">Confirm</button></td>
      </tr>
    `).join('');
  }

  window.confirmBooking = async (id) => {
    const { error } = await supabase
      .from('bookings')
      .update({ status: 'confirmed' })
      .eq('id', id);

    if (error) console.error('Error confirming:', error.message);
    else loadBookings();
  };

  document.getElementById('logout-btn').addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });

  checkAuth();
  loadBookings();
</script>

<style>
  .admin-container { padding: 2rem; max-width: 1000px; margin: 0 auto; background: rgba(255, 255, 255, 0.4); border-radius: 15px; backdrop-filter: blur(5px); }
  .header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  h1 { margin: 0; color: var(--dark-charcoal); }
  table { width: 100%; border-collapse: collapse; background: rgba(255, 255, 255, 0.2); border-radius: 10px; }
  th, td { border: 1px solid var(--mountain-clay); padding: 0.75rem; text-align: center; color: var(--dark-charcoal); }
  th { background: rgba(255, 255, 255, 0.3); }
  .signup-btn { text-decoration: none; display: inline-block; cursor: pointer; background: var(--mountain-clay); border: none; padding: 0.5rem 1rem; border-radius: 5px; color: white; font-weight: bold; }
  .signup-btn:hover { background: var(--palm-green); }
  .submit-btn { cursor: pointer; background: var(--palm-green); border: none; padding: 0.4rem 0.8rem; border-radius: 5px; color: white; font-weight: bold; transition: background 0.2s; }
  .submit-btn:hover { background: var(--mountain-clay); }
  .cancel-btn { cursor: pointer; background: #ccc; border: none; padding: 0.8rem; border-radius: 5px; margin-top: 1rem; color: var(--dark-charcoal); }
  .phone-link { color: var(--dark-charcoal); text-decoration: underline; }
</style>
