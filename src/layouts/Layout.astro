---
interface Props {
	title?: string;
}

const { title = "Coachella Rides" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		font-family: 'Inter', system-ui, -apple-system, sans-serif;
		color: #033;
	}
	/* Background image setup with 50% opacity */
	body::before {
		content: "";
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: url('/coachella-sky-gradient.png');
		background-size: cover;
		background-position: center;
		opacity: 0.5;
		z-index: -1;
	}
</style>
