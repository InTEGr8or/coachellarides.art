---
interface Props {
	title?: string;
}

const { title = "Coachella Rides" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--sunset-purple: #3A1C71;
		--sunset-pink: #D76D77;
		--sunset-orange: #FFAF7B;
	}
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: sans-serif;
		background: linear-gradient(to bottom, var(--sunset-purple), var(--sunset-pink));
		color: white;
	}
</style>
